# Configuración del servidor
PORT=3001
# Set NODE_ENV=production in deploys to enable CORS whitelist + strict JWT_SECRET
NODE_ENV=development

# Configuración de PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=spkcup
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=20

# JWT — MUST be at least 16 chars. Refuses to boot in production without a strong value.
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# CORS — comma-separated list of allowed origins (used when NODE_ENV=production)
# e.g. CORS_ORIGINS=https://spk-cup.com,https://admin.spk-cup.com
CORS_ORIGINS=
